# MongoDB
MONGO_URI=mongodb://mongo:27017/ai-agent

# Auth (required)
JWT_SECRET=change-this-to-a-secure-random-string

# LLM Providers (optional)
GROQ_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://host.docker.internal:11434

# Email (optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Worker (optional tuning)
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=1
WORKER_MAX_ATTEMPTS=3

# Optional host port overrides
MONGO_PORT=27017
BACKEND_PORT=5000
FRONTEND_PORT=3000
NGINX_PORT=80

