{
  "info": {
    "name": "AI Agent Automation API",
    "description": "Complete Postman collection for the AI Agent Automation platform. Covers Authentication, Agents, Workflows, Tasks, Schedules, Webhooks, Documents/RAG, Memory, Settings, Logs, Telemetry, and more.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Mehdi\",\n  \"email\": \"ali@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/stats"
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "List Agents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/agents"
          }
        },
        {
          "name": "Create Agent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/agents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Agent\",\n  \"description\": \"Test agent\",\n  \"config\": {\n    \"provider\": \"groq\",\n    \"model\": \"llama-3.1-8b-instant\",\n    \"temperature\": 0.7\n  }\n}"
            }
          }
        },
        {
          "name": "Get Agent",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/agents/:id",
            "variable": [{ "key": "id", "value": "AGENT_ID_HERE" }]
          }
        },
        {
          "name": "Update Agent",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/agents/:id",
            "variable": [{ "key": "id", "value": "AGENT_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Agent Name\",\n  \"config\": {\n    \"temperature\": 0.5\n  }\n}"
            }
          }
        },
        {
          "name": "Delete Agent",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/agents/:id",
            "variable": [{ "key": "id", "value": "AGENT_ID_HERE" }]
          }
        },
        {
          "name": "Run Agent (Playground)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/agents/:id/run",
            "variable": [{ "key": "id", "value": "AGENT_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Summarize the concept of semantic memory\",\n  \"useMemory\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Workflows",
      "item": [
        {
          "name": "List Workflows",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/workflows"
          }
        },
        {
          "name": "Create Workflow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workflows",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Workflow\",\n  \"description\": \"Test workflow\",\n  \"nodes\": [],\n  \"edges\": []\n}"
            }
          }
        },
        {
          "name": "Get Workflow",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/workflows/:id",
            "variable": [{ "key": "id", "value": "WORKFLOW_ID_HERE" }]
          }
        },
        {
          "name": "Update Workflow",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workflows/:id",
            "variable": [{ "key": "id", "value": "WORKFLOW_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Workflow\"\n}"
            }
          }
        },
        {
          "name": "Delete Workflow",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/workflows/:id",
            "variable": [{ "key": "id", "value": "WORKFLOW_ID_HERE" }]
          }
        },
        {
          "name": "Run Workflow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workflows/:id/run",
            "variable": [{ "key": "id", "value": "WORKFLOW_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Get Task",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks/:id",
            "variable": [{ "key": "id", "value": "TASK_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Schedules",
      "item": [
        {
          "name": "List Schedules",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/schedules"
          }
        },
        {
          "name": "Create Schedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/schedules",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workflowId\": \"WORKFLOW_ID_HERE\",\n  \"cron\": \"0 9 * * *\",\n  \"enabled\": true\n}"
            }
          }
        },
        {
          "name": "Delete Schedule",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/schedules/:id",
            "variable": [{ "key": "id", "value": "SCHEDULE_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "List Webhooks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/webhooks"
          }
        },
        {
          "name": "Create Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/webhooks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workflowId\": \"WORKFLOW_ID_HERE\",\n  \"name\": \"My Webhook\"\n}"
            }
          }
        },
        {
          "name": "Trigger Webhook (Public)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/webhook/:token",
            "variable": [{ "key": "token", "value": "WEBHOOK_TOKEN_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": \"test payload\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Documents / RAG",
      "item": [
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/documents"
          }
        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/documents",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "agentId", "value": "AGENT_ID_HERE", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Get Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/documents/:id",
            "variable": [{ "key": "id", "value": "DOCUMENT_ID_HERE" }]
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/documents/:id",
            "variable": [{ "key": "id", "value": "DOCUMENT_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Memory",
      "item": [
        {
          "name": "List All Memories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/memory"
          }
        },
        {
          "name": "List Agents with Memory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/memory/agents"
          }
        },
        {
          "name": "Delete Memory Entry",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/memory/:id",
            "variable": [{ "key": "id", "value": "MEMORY_ID_HERE" }]
          }
        },
        {
          "name": "Clear Agent Memory",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/memory/agent/:agentId",
            "variable": [{ "key": "agentId", "value": "AGENT_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/settings"
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/settings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"theme\": \"dark\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Logs",
      "item": [
        {
          "name": "List Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/logs"
          }
        }
      ]
    },
    {
      "name": "Telemetry",
      "item": [
        {
          "name": "Get Telemetry",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/telemetry"
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Get Providers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/system/providers"
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        {
          "name": "List Templates",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/templates"
          }
        }
      ]
    }
  ]
}
