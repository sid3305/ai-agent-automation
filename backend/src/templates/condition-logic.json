{
  "id": "condition-logic",
  "name": "Condition Logic",
  "description": "Basic template to check the condition logic",
  "category": "Custom",
  "icon": "⚙️",
  "tags": [
    "workflow"
  ],
  "steps": [
    {
      "stepId": "first",
      "name": "First",
      "position": {
        "x": -80,
        "y": -560
      },
      "type": "llm",
      "prompt": "earth is not flat",
      "useMemory": false,
      "memoryTopK": 5
    },
    {
      "stepId": "condition",
      "name": "Condition",
      "position": {
        "x": -80,
        "y": -360
      },
      "type": "condition",
      "conditionType": "boolean",
      "operator": "isTrue",
      "value": ""
    },
    {
      "stepId": "negative",
      "name": "Negative",
      "position": {
        "x": -240,
        "y": -120
      },
      "type": "file",
      "action": "write",
      "path": "runtime/negative.txt",
      "content": "False bro"
    },
    {
      "stepId": "positive",
      "name": "Positive",
      "position": {
        "x": 80,
        "y": -120
      },
      "type": "file",
      "action": "write",
      "path": "runtime/positive.txt",
      "content": "True bro"
    },
    {
      "stepId": "delay_neg",
      "name": "Delay Negative",
      "position": {
        "x": -240,
        "y": 40
      },
      "type": "delay",
      "seconds": 10
    },
    {
      "stepId": "llm_neg",
      "name": "LLM Negative",
      "position": {
        "x": -240,
        "y": 200
      },
      "type": "llm",
      "prompt": "so earth is really not flat?",
      "useMemory": false,
      "memoryTopK": 5
    },
    {
      "stepId": "delay_pos",
      "name": "Delay Positive",
      "position": {
        "x": 80,
        "y": 40
      },
      "type": "delay",
      "seconds": 5
    },
    {
      "stepId": "result",
      "name": "Result",
      "position": {
        "x": -80,
        "y": 440
      },
      "type": "file",
      "action": "write",
      "path": "runtime/finalresult.txt",
      "content": "{{last.output}}"
    },
    {
      "stepId": "llm_pos",
      "name": "LLM Positive",
      "position": {
        "x": 80,
        "y": 200
      },
      "type": "llm",
      "prompt": "so earth is really flat?",
      "useMemory": false,
      "memoryTopK": 5
    }
  ],
  "edges": [
    {
      "id": "first-to-condition",
      "source": "first",
      "target": "condition"
    },
    {
      "id": "condition-to-neg",
      "source": "condition",
      "target": "negative",
      "condition": "false",
      "label": "false"
    },
    {
      "id": "condition-to-pos",
      "source": "condition",
      "target": "positive",
      "condition": "true",
      "label": "true"
    },
    {
      "id": "neg-to-delayneg",
      "source": "negative",
      "target": "delay_neg"
    },
    {
      "id": "delayneg-to-llmneg",
      "source": "delay_neg",
      "target": "llm_neg"
    },
    {
      "id": "llmneg-to-result",
      "source": "llm_neg",
      "target": "result"
    },
    {
      "id": "pos-to-delaypos",
      "source": "positive",
      "target": "delay_pos"
    },
    {
      "id": "delaypos-to-llmpos",
      "source": "delay_pos",
      "target": "llm_pos"
    },
    {
      "id": "llmpos-to-result",
      "source": "llm_pos",
      "target": "result"
    }
  ]
